# ==============================================================================
# bitcoin-stack — environment configuration
# Copy this file to .env and fill in your values.
# ==============================================================================

# ------------------------------------------------------------------------------
# Storage layout
#
# This stack is designed for a two-disk setup:
#
#   HDD  — large/slow disk for heavy blockchain data
#   NVMe — fast disk for indexes and application data
#
# Recommended layout:
#
#   HDD  (/mnt/hd)
#   └── bitcoin/              ← Bitcoin Core blockchain (~700 GB)
#
#   NVMe (/home/<user>)
#   ├── fulcrum-data/         ← Fulcrum index (~100 GB)
#   ├── elements-data/        ← Liquid Network blockchain (~10 GB)
#   ├── electrs-liquid-data/  ← electrs Liquid index (~5 GB)
#   └── canary-data/          ← Canary wallet monitor (< 1 GB)
#
# ------------------------------------------------------------------------------

# ── Tor ───────────────────────────────────────────────────────────────────────
TOR_CONTROL_PASSWORD=change_me_strong_password

# ── Bitcoin Core ───────────────────────────────────────────────────────────────
BITCOIN_VERSION=28.1
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=change_me_strong_password

# HDD — blockchain data directory (heavy, ~700 GB)
BITCOIN_DATA=/mnt/hd/bitcoin

# ── Fulcrum (Electrum server for Bitcoin) ──────────────────────────────────────
FULCRUM_VERSION=2.1.0

# NVMe — Fulcrum index (~100 GB, grows with blockchain)
FULCRUM_DATA=/home/<user>/fulcrum-data

# ── Elements / Liquid Network ──────────────────────────────────────────────────
ELEMENTS_VERSION=23.3.2
ELEMENTS_RPC_USER=elements
ELEMENTS_RPC_PASSWORD=change_me_strong_password

# NVMe — Liquid blockchain data (~10 GB)
ELEMENTS_DATA=/home/<user>/elements-data

# NVMe — electrs Liquid index (~5 GB)
FULCRUM_LIQUID_DATA=/home/<user>/electrs-liquid-data

# ── Canary (Bitcoin wallet monitor) ───────────────────────────────────────────
# NVMe — SQLite database and app data (< 1 GB)
CANARY_DATA=/home/<user>/canary-data
