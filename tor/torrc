DataDirectory /var/lib/tor
PidFile /var/run/tor/tor.pid

# SOCKS5 proxy - acessível para os containers na rede interna Docker
SocksPort 0.0.0.0:9050

# Control port - usado pelo Bitcoin Core para criar automaticamente o hidden service v3
ControlPort 0.0.0.0:9051
# HashedControlPassword é injetado em runtime pelo entrypoint via TOR_HASHED_PASSWORD

Log notice stderr
